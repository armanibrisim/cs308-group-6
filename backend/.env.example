# Firebase service account JSON dosyasının yolu
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# JWT secret key - change this to a strong random string in production
SECRET_KEY=your-secret-key-here

# AES-256-GCM key for field-level Firestore encryption
# Generate: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=replace-with-64-hex-chars

# HMAC-SHA256 key for non-reversible Firestore query hashes
# Generate: python -c "import os; print(os.urandom(32).hex())"
HMAC_KEY=replace-with-64-hex-chars
